# ─────────────────────────────────────────────────────────────
# Pi Backend — environment variables
# Copy to `.env` and fill in real secrets. Never commit .env
# ─────────────────────────────────────────────────────────────

# App
APP_ENV=development                    # development | staging | production
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-64-random-chars
APP_BASE_URL=http://localhost:8000
APP_CORS_ORIGINS=http://localhost,https://saigonhouse.local

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://pi:pi@localhost:5432/pi_backend
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis (cache + rate limit + celery broker)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# JWT
JWT_SECRET=change-me-to-64-random-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080                # 7 days
SQLADMIN_SESSION_SECRET=replace-with-strong-random-string

# License API — keys Pi plugins send in Authorization: Bearer <key>
LICENSE_KEY_PREFIX=pi_                   # generated license keys start with this
LICENSE_DEFAULT_TIER=free                # free | pro | max

# Legacy direct AI keys (still used by Pi SEO /v1/seo/bot directly — can remove once all calls
# go through Pi AI Cloud /v1/ai/complete which reads PI_AI_KEY_* below)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ─────────────────────────────────────────────────────────────
# Pi AI Cloud — upstream provider API keys
# ─────────────────────────────────────────────────────────────
# These are FREE-tier keys of providers that Pi routes requests to.
# Customers never see these — they just buy Pi tokens and Pi dispatches.
# Each key maps to a row in ai_providers table by slug (upper + underscore).

PI_AI_KEY_GROQ_LLAMA_70B_FREE=           # https://console.groq.com — free tier
PI_AI_KEY_GEMINI_2_FLASH_FREE=           # https://aistudio.google.com — free tier
PI_AI_KEY_MISTRAL_SMALL_FREE=            # https://console.mistral.ai — free tier
PI_AI_KEY_COHERE_COMMAND_FREE=           # https://dashboard.cohere.com — free tier
PI_AI_KEY_TOGETHER_LLAMA_FREE=           # https://api.together.xyz — small free tier
PI_AI_KEY_ANTHROPIC_SONNET_PAID=         # Paid fallback — keep empty until needed
PI_AI_KEY_OPENAI_GPT4O_PAID=             # Paid fallback

# Stripe — token top-up billing
STRIPE_SECRET_KEY=sk_test_...            # from https://dashboard.stripe.com
STRIPE_WEBHOOK_SECRET=whsec_...          # from Stripe CLI or Dashboard → Webhooks
STRIPE_PUBLISHABLE_KEY=pk_test_...       # client-side only (optional here)

# Rate limits (requests per window)
RATE_LIMIT_FREE_PER_MONTH=5000
RATE_LIMIT_PRO_PER_MONTH=100000
RATE_LIMIT_MAX_PER_MONTH=500000
RATE_LIMIT_BURST_PER_MINUTE=10

# Stripe subscription billing
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_MAX_PRICE_ID=price_...

# SMTP email delivery
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@pi-ecosystem.com

# Plugin update server
UPDATES_STORAGE_PATH=./data/plugin-releases
UPDATES_SIGNING_KEY=change-me

# ─────────────────────────────────────────────────────────────
# Feature flags
# ─────────────────────────────────────────────────────────────

# Enable new per-package routing engine (default: false for backwards-compat)
# When true, ProviderRouter uses package.routing_mode + dedicated_key_count
# instead of legacy round-robin shared pool.
PI_AI_NEW_ROUTING_ENABLED=false

# Google Indexing API — path to service-account JSON file or inline JSON string
# Required for real Google Indexing API submissions from /v1/seo/indexing/submit
# See: https://developers.google.com/search/apis/indexing-api/v3/quickstart
GOOGLE_INDEXING_SERVICE_ACCOUNT_JSON=

# Email delivery — Resend API (primary, 3k/month free)
RESEND_API_KEY=re_...
EMAIL_FROM=Pi Ecosystem <no-reply@pi-ecosystem.com>
EMAIL_REPLY_TO=support@pi-ecosystem.com

# OAuth social login
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
OAUTH_REDIRECT_BASE=https://api.pi-ecosystem.com/v1/auth/oauth

# Frontend URLs (for email links + OAuth redirects)
FRONTEND_STORE_URL=https://store.pi-ecosystem.com
FRONTEND_DASHBOARD_URL=https://app.pi-ecosystem.com

# Logging / monitoring
LOG_LEVEL=INFO
SENTRY_DSN=
